# Staging Environment Configuration
# ====================================
DATABASE_URL=postgresql://db-staging.internal:5432/myapp_staging
DATABASE_HOST=db-staging.internal
DATABASE_PORT=5432
DATABASE_NAME=myapp_staging
DATABASE_USER=stg_user
DATABASE_PASSWORD=stg-secure-password-abc123

REDIS_URL=redis://redis-staging.internal:6379/0

API_URL=https://staging-api.myapp.com
BASE_URL=https://staging.myapp.com

DEBUG=false
LOG_LEVEL=info
NODE_ENV=staging

# Security
SECRET_KEY=staging-real-secret-key-xyz
JWT_SECRET=staging-jwt-real-secret
API_KEY=sk-staging-live-key-abc123def456
ENCRYPTION_KEY=staging-enc-key-32chars-long

# Feature Flags
FEATURE_NEW_UI=true
FEATURE_BETA_SEARCH=true
FEATURE_DARK_MODE=true

# Limits
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT=500
SESSION_TIMEOUT=7200

# Email
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=staging@mg.myapp.com
MAIL_PASSWORD=real-mail-password-stg

# Staging-specific
NEW_RELIC_ENABLED=true
