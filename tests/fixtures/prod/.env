# Production Environment Configuration
# =====================================
DATABASE_URL=postgresql://db-prod-primary.internal:5432/myapp_prod
DATABASE_HOST=db-prod-primary.internal
DATABASE_HOST_READONLY=db-prod-replica.internal
DATABASE_PORT=5432
DATABASE_NAME=myapp_prod
DATABASE_USER=prod_user
DATABASE_PASSWORD=prod-super-secure-pw-987xyz

REDIS_URL=redis://redis-cluster.internal:6379/0

API_URL=https://api.myapp.com
BASE_URL=https://myapp.com

DEBUG=false
LOG_LEVEL=warn
NODE_ENV=production

# Security
SECRET_KEY=prod-real-secret-key-512bit-hash
JWT_SECRET=prod-jwt-real-secret-key
API_KEY=sk-prod-live-key-xyz789abc012
ENCRYPTION_KEY=prod-enc-key-64chars-really-long-and-secure

# Feature Flags
FEATURE_NEW_UI=true
FEATURE_BETA_SEARCH=true
FEATURE_DARK_MODE=false

# Limits
MAX_UPLOAD_SIZE=104857600
RATE_LIMIT=1000
SESSION_TIMEOUT=86400

# Email
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USER=prod@mg.myapp.com
MAIL_PASSWORD=real-sendgrid-api-key-prod

# Production monitoring
NEW_RELIC_ENABLED=true
SENTRY_DSN=https://abc123@sentry.io/prod
DD_ENV=production
DD_SERVICE=myapp

# Production-only keys
PROD_ONLY_CONFIG=some-prod-value
